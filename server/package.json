{
  "name": "docintelligence-server",
  "version": "1.0.0",
  "description": "DocIntelligence backend — AI-powered document processor",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest --coverage --forceExit --runInBand",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "groq-sdk": "^0.3.3",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "lines": 80
      }
    },
    "collectCoverageFrom": [
      "**/*.js",
      "!node_modules/**",
      "!jest.config.js",
      "!uploads/**",
      "!coverage/**",
      "!__tests__/**"
    ]
  }
}
